      "parameters": {
        "jsCode": "function asObject(value) {\n  return value && typeof value === 'object' && !Array.isArray(value) ? value : {};\n}\n\nfunction safeText(value, fallback = '') {\n  const text = String(value ?? '').trim();\n  return text || fallback;\n}\n\nconst input = $json ?? {};\nconst action = safeText(input.action, 'upsert');\nconst tableName = safeText(input.tableName);\nconst keyField = safeText(input.keyField);\nconst keyValue = safeText(input.keyValue);\nconst inputData = asObject(input.data);\n\nif (!['get', 'upsert', 'delete'].includes(action)) {\n  throw new Error('DataTableStore only supports action=get|upsert|delete.');\n}\n\nif (!tableName) {\n  throw new Error('tableName is required.');\n}\n\nif (!keyField) {\n  throw new Error('keyField is required.');\n}\n\nif (!keyValue) {\n  throw new Error('keyValue is required.');\n}\n\nconst rowData = {\n  ...inputData,\n  [keyField]: inputData[keyField] ?? keyValue,\n};\n\nreturn {\n  _action: action,\n  _tableName: tableName,\n  _keyField: keyField,\n  _keyValue: keyValue,\n  _rowData: rowData,\n};"
      },
