        "jsCode": "function safeParseObject(value) {\n  if (typeof value !== 'string' || value.trim() === '') {\n    return null;\n  }\n\n  try {\n    const parsed = JSON.parse(value);\n    return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : null;\n  } catch (error) {\n    return null;\n  }\n}\n\nconst input = $json ?? {};\nconst storedRow = safeParseObject(input.dataJson);\nconst found = storedRow !== null;\n\nreturn {\n  status: 'success',\n  found,\n  row: found ? storedRow : null,\n};"
