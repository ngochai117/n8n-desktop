    {
      "parameters": {
        "jsCode": "function normalizeText(value) {\n  return String(value ?? '').replace(/\\r\\n/g, '\\n').trim();\n}\n\nfunction asObject(value) {\n  return value && typeof value === 'object' && !Array.isArray(value) ? value : {};\n}\n\nfunction asArray(value) {\n  return Array.isArray(value) ? value : [];\n}\n\nconst content = asObject($('Content AI Agent').first().json.output);\nconst metadata = asObject($('Metadata AI Agent').first().json.output);\nconst qc = asObject($('QC AI Agent').first().json.output);\n\nif (Object.keys(content).length === 0) {\n  throw new Error('Content output is missing from merged payload.');\n}\n\nif (Object.keys(metadata).length === 0) {\n  throw new Error('Metadata output is missing from merged payload.');\n}\n\nif (Object.keys(qc).length === 0) {\n  throw new Error('QC output is missing from merged payload.');\n}\n\nconst manifest = {\n  ...content,\n  metadata: {\n    ...metadata,\n    title: normalizeText(metadata.title),\n    caption: normalizeText(metadata.caption),\n    thumbnail_text: normalizeText(metadata.thumbnail_text),\n    hashtags: asArray(metadata.hashtags),\n  },\n  scenes: asArray(content.scenes).map((s, i) => ({\n    ...asObject(s),\n    scene_id: String(s?.scene_id ??       'scene_' + String(i + 1).padStart(2, '0')),\n    narration_text: normalizeText(s?.narration_text),\n  })),\n};\n\nreturn {\n  ...content,\n  manifest,\n  manifestJSONString: JSON.stringify(manifest, null, 2),\n  qc,\n};\n"
      },
