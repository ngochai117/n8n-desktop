        "mode": "runOnceForEachItem",
        "jsCode": "const input = $json ?? {};\n\nfunction safeText(value, fallback = '') {\n  const text = String(value ?? '').trim();\n  return text || fallback;\n}\n\nconst rawAction = safeText(input.action, 'ensureAndWrite').toLowerCase();\nconst action = rawAction === 'ensuresheet'\n  ? 'ensureSheet'\n  : (rawAction === 'writerows' ? 'writeRows' : 'ensureAndWrite');\n\nconst sessionSheetId = safeText(input.session_sheet_id, safeText(input.sheetId));\nconst sessionSheetName = safeText(input.session_sheet_name, safeText(input.sheetName, 'book-review-assets'));\nconst sheetTabName = safeText(input.sheetTabName, 'assets');\nconst targetFolderId = safeText(input.session_folder_id, safeText(input.targetFolderId));\nconst sheetRows = Array.isArray(input.session_sheet_rows)\n  ? input.session_sheet_rows\n  : (Array.isArray(input.sheetRows) ? input.sheetRows : []);\n\nconst shouldEnsure = action === 'ensureAndWrite' || action === 'ensureSheet';\nconst shouldWrite = action === 'ensureAndWrite' || action === 'writeRows';\nconst shouldMove = shouldEnsure && targetFolderId !== '';\nconst shouldCreateSheet = shouldEnsure && sessionSheetId === '';\nconst missingSheetIdForWrite = action === 'writeRows' && sessionSheetId === '';\nconst shouldCallWriteApi = shouldWrite && !missingSheetIdForWrite;\n\nreturn {\n  ...input,\n  action,\n  sheetId: sessionSheetId,\n  sheetName: sessionSheetName,\n  sheetTabName,\n  targetFolderId,\n  sheetRows,\n  shouldEnsure,\n  shouldWrite,\n  shouldMove,\n  shouldCreateSheet,\n  missingSheetIdForWrite,\n  shouldCallWriteApi,\n};"
      },
