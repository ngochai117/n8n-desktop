        "jsCode": "const input = $json ?? {};\n\nfunction safeText(value, fallback = '') {\n  const text = String(value ?? '').trim();\n  return text || fallback;\n}\n\nconst body = input.body && typeof input.body === 'object' ? input.body : {};\nconst sheetId = safeText(body.spreadsheetId, safeText(input.sheetId, safeText(input.session_sheet_id)));\nconst sheetUrl = safeText(\n  body.spreadsheetUrl,\n  safeText(input.sheetUrl, sheetId ? 'https://docs.google.com/spreadsheets/d/' + sheetId : ''),\n);\n\nconst createStatusCode = Number(input.statusCode ?? 0);\n\nreturn {\n  ...input,\n  session_sheet_id: sheetId,\n  session_sheet_url: sheetUrl,\n  session_sheet_create_status_code: Number.isFinite(createStatusCode) ? createStatusCode : 0,\n};"
