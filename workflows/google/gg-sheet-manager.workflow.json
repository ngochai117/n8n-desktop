      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $json ?? {};\n\nfunction safeText(value, fallback = '') {\n  const text = String(value ?? '').trim();\n  return text || fallback;\n}\n\nconst sheetId = safeText(input.session_sheet_id);\nconst sheetUrl = safeText(input.session_sheet_url, sheetId ? 'https://docs.google.com/spreadsheets/d/' + sheetId : '');\n\nconst writeStatusCodeRaw = Number(input.session_sheet_update_status_code ?? 0);\nconst writeStatusCode = Number.isFinite(writeStatusCodeRaw) ? writeStatusCodeRaw : 0;\nconst writeOk = input.shouldWrite !== true\n  ? true\n  : (input.missingSheetIdForWrite === true\n      ? false\n      : (writeStatusCode >= 200 && writeStatusCode < 300));\nconst ensureOk = input.shouldEnsure !== true || sheetId !== '';\n\nreturn {\n  ...input,\n  status: ensureOk && writeOk ? 'success' : 'partial',\n  sheetId,\n  sheetUrl,\n  session_sheet_id: sheetId,\n  session_sheet_url: sheetUrl,\n  session_sheet_create_status_code: Number(input.session_sheet_create_status_code ?? 0),\n  session_sheet_update_status_code: writeStatusCode,\n};"
