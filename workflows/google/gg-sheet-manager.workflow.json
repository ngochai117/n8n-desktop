        "mode": "runOnceForEachItem",
        "jsCode": "const input = $json ?? {};\n\nfunction safeText(value, fallback = '') {\n  const text = String(value ?? '').trim();\n  return text || fallback;\n}\n\nconst rawAction = safeText(input.action, 'ensureAndWrite').toLowerCase();\nconst action = rawAction === 'ensuresheet'\n  ? 'ensureSheet'\n  : (rawAction === 'writerows' ? 'writeRows' : 'ensureAndWrite');\n\nconst spreadsheetId = safeText(input.spreadsheetId);\nconst spreadsheetName = safeText(input.spreadsheetName, 'untitled-sheet');\nconst sheetName = safeText(input.sheetName, 'Sheet1');\nconst folderId = safeText(input.folderId);\nconst rows = Array.isArray(input.rows) ? input.rows : [];\nconst writeRange = safeText(input.range, sheetName + '!A1');\n\nconst normalizedValueInputOption = safeText(input.valueInputOption, 'RAW').toUpperCase();\nconst valueInputOption = normalizedValueInputOption === 'USER_ENTERED'\n  ? 'USER_ENTERED'\n  : 'RAW';\n\nconst shouldEnsure = action === 'ensureAndWrite' || action === 'ensureSheet';\nconst shouldWrite = action === 'ensureAndWrite' || action === 'writeRows';\nconst shouldMove = shouldEnsure && folderId !== '';\nconst shouldCreateSheet = shouldEnsure && spreadsheetId === '';\nconst missingSpreadsheetIdForWrite = action === 'writeRows' && spreadsheetId === '';\nconst shouldCallWriteApi = shouldWrite && !missingSpreadsheetIdForWrite;\n\nreturn {\n  ...input,\n  action,\n  spreadsheetId,\n  spreadsheetName,\n  sheetName,\n  folderId,\n  rows,\n  writeRange,\n  valueInputOption,\n  shouldEnsure,\n  shouldWrite,\n  shouldMove,\n  shouldCreateSheet,\n  missingSpreadsheetIdForWrite,\n  shouldCallWriteApi,\n};"
      },
